# Postgres pooler URI from Supabase → Project Settings → Database (Session or Transaction).
# DATABASE_URL overrides SUPABASE_URL when both are set. URL-encode password characters like , @ : $ #.
DATABASE_URL=
SUPABASE_URL=postgresql://postgres.<project-ref>:YOUR_PASSWORD@aws-0-....pooler.supabase.com:5432/postgres

LANGGRAPH_DEPLOYMENT_URL=http://localhost:8000
# Must match the graph name in agent/langgraph.json and the frontend agent prop
LANGGRAPH_GRAPH_ID=cyber_risk